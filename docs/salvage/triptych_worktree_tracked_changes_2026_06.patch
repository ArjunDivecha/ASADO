+def _pct_str(val, decimals=1):
+    try:
+        if pd.isna(val):
+            return "n/a"
+        return f"{float(val) * 100:.{decimals}f}%"
+    except (TypeError, ValueError):
+        return "n/a"
+
+
+def _render_triptych_opportunity_detail(row):
+    """Render one opportunity detail panel inside a modal or inline fallback."""
+    country = row.get("country", "")
+    factor = row.get("factor", "")
+    horizon = int(row.get("horizon_months", 0) or 0)
+    st.markdown(f"#### {country} / {factor}")
+    st.caption(
+        f"{horizon}M {row.get('return_mode', '')} returns | "
+        f"{row.get('normalization', '')} | current decile {int(row.get('current_decile', 0) or 0)}"
+    )
+
+    col1, col2, col3, col4 = st.columns(4)
+    col1.metric("Slope / bucket", _pct_str(row.get("slope_per_bucket")))
+    col2.metric("R-squared", f"{float(row.get('r_squared', 0) or 0):.2f}")
+    col3.metric("Endpoint edge", _pct_str(row.get("bucket_edge_spread")))
+    col4.metric("Sample size", f"{int(row.get('sample_size', 0) or 0):,}")
+
+    endpoint_df = pd.DataFrame({
+        "Bucket": ["Bucket 1", "Bucket 10"],
+        "Forward Return": [row.get("bucket_1_avg"), row.get("bucket_10_avg")],
+    })
+    colors = ["#5fa27c" if v >= 0 else "#bd756e" for v in endpoint_df["Forward Return"]]
+    fig = go.Figure(go.Bar(
+        x=endpoint_df["Bucket"],
+        y=endpoint_df["Forward Return"],
+        marker_color=colors,
+        text=[_pct_str(v) for v in endpoint_df["Forward Return"]],
+        textposition="outside",
+    ))
+    fig.update_layout(
