+        yaxis_tickformat=".0%",
+        paper_bgcolor="rgba(0,0,0,0)",
+        plot_bgcolor="rgba(0,0,0,0)",
+        font=dict(color="#E5E7EB", size=11),
+    )
+    st.plotly_chart(fig, use_container_width=True)
+
+    st.info(
+        "Discovery scan only: this row comes from full-sample thresholds. "
