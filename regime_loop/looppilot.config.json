{
  "project_name": "regime-conditioning-optimization",

  "target": {
    "root_dir": "../regime",
    "modifiable_files": [
      "src/regime_tagger.py",
      "src/data_loader.py",
      "src/ic_analysis.py",
      "src/backtest.py",
      "src/utils.py",
      "run_regime_test.py",
      "regime.md",
      "regime2.md",
      "results/*",
      "results/figures/*",
      "data/*",
      "data/processed/*",
      "data/raw/*",
      "__pycache__/*",
      "src/__pycache__/*",
      "tests/__pycache__/*"
    ],
    "creatable_patterns": [],
    "protected_files": [
      "PRD.md",
      ".env"
    ],
    "eval_command": "/Users/arjundivecha/Dropbox/AAA\\ Backup/A\\ Working/ASADO/venv/bin/python run_regime_test.py --json-output 2>/dev/null",
    "eval_timeout_seconds": 120
  },

  "metrics": {
    "primary": {
      "name": "all_pass",
      "direction": "maximize",
      "format": "%.0f"
    },
    "secondary": [
      {
        "name": "weighted_persist_1m",
        "direction": "maximize",
        "floor": 0.50,
        "format": "%.3f"
      },
      {
        "name": "n_sig_factors",
        "direction": "maximize",
        "floor": 0,
        "format": "%.0f"
      },
      {
        "name": "sharpe_delta",
        "direction": "maximize",
        "floor": -1.0,
        "format": "%.3f"
      },
      {
        "name": "h1_pass",
        "direction": "maximize",
        "format": "%.0f"
      }
    ],
    "parse_from": "json_stdout"
  },

  "gating": {
    "mode": "single",
    "promote_threshold": 0.001,
    "floor_metric": null,
    "floor_value": null,
    "max_consecutive_retires": 8
  },

  "checkpoints": {
    "cycle_interval": 5,
    "cycle_interval_class": "FYI",
    "plateau_threshold": 10,
    "error_streak_threshold": 10,
    "regression_threshold_pct": 50,
    "milestone_threshold_pct": 10,
    "identical_hold_threshold": 3,
    "max_unresolved_holds": 5,
    "decision_timeout_minutes": 30,
    "default_decision": "continue",
    "decision_defaults": {
      "plateau": "continue",
      "error_streak": "continue",
      "large_regression": "continue",
      "identical_holds": "continue",
      "hold_stack_full": "continue",
      "branch_point": "continue",
      "strategy_exhausted": "pause"
    }
  },

  "loop": {
    "max_iterations": 30,
    "agent_backend": "claude",
    "agent_model": "claude-sonnet-4-6",
    "agent_timeout_seconds": 1800,
    "git_commit_on_promote": false,
    "web_search_on_plateau": true,
    "web_search_on_human_reference": false
  },

  "telegram": {
    "bot_token": "7892051265:AAGYZkHS9NrohKVw09qOa9tBdmQOZsa7idY",
    "chat_id": 7502822815,
    "report_style": "summary_plus_link"
  }
}
